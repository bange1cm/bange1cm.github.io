---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import { projects } from '../../data/projects';
function splitDetails(details: string | string[]): string[] {
	if (!details) return [];
	if (Array.isArray(details)) return details.map(d => String(d).trim()).filter(Boolean);

	const text = String(details).trim();
	// First split on explicit newlines
	const lines = text.split(/\r?\n/).map(l => l.trim()).filter(Boolean);
	if (lines.length > 1) return lines;

	// Fallback: split into sentences for better readability
	const sentences = text
		.split(/(?<=[.?!])\s+(?=[A-Z0-9"“'`])/)
		.map(s => s.trim())
		.filter(Boolean);

	return sentences.length ? sentences : [text];
}

interface Props {
	project: typeof projects[0];
}

const { project } = Astro.props as Props;

function getYouTubeEmbed(url: string) {
	if (!url) return '';
	try {
		const u = new URL(url);
		if (u.hostname === 'youtu.be') {
			return `https://www.youtube.com/embed/${u.pathname.slice(1)}`;
		}
		if (u.hostname.includes('youtube.com')) {
			const v = u.searchParams.get('v');
			if (v) return `https://www.youtube.com/embed/${v}`;
			const pathParts = u.pathname.split('/');
			const idx = pathParts.indexOf('embed');
			if (idx >= 0 && pathParts[idx + 1]) return `https://www.youtube.com/embed/${pathParts[idx + 1]}`;
		}
	} catch (e) {}
	return url;
}

export async function getStaticPaths() {
	return projects.map(project => ({
		params: { id: project.id },
		props: { project }
	}));
}

---

<Layout>
	<Navigation />
	<div class="project-detail-container">
		<a href="/projects" class="back-link">← Back to Projects</a>

		<header class="project-header">
			<h1>{project.title}</h1>
			<span class="category-badge">{project.category}</span>
		</header>

		{project.video ? (
			<div class="project-video">
				<iframe src={getYouTubeEmbed(project.video)} title={project.title}
					frameborder="0"
					allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
					allowfullscreen></iframe>
			</div>
		) : project.images && project.images.length > 0 ? (
			<div class="project-slideshow">
				<div class="slideshow-container">
					{project.images.map((img, idx) => (
						<div class="slide" id={`slide-${idx}`}>
							<img src={img} alt={`${project.title} - Image ${idx + 1}`} />
						</div>
					))}
					<a class="prev" onclick="changeSlide(-1)">❮</a>
					<a class="next" onclick="changeSlide(1)">❯</a>
				</div>
				<div class="dots">
					{project.images.map((_, idx) => (
						<span class="dot" id={`dot-${idx}`} onclick={`currentSlide(${idx})`}></span>
					))}
				</div>
			</div>
		) : project.image && (
			<div class="project-image-large">
				<img src={project.image} alt={project.title} />
			</div>
		)}

		<div class="project-content">
			<section class="project-section">
				<h2>Overview</h2>
				<p>{project.description}</p>
				{project.details && (
					splitDetails(project.details).map(line => (
						<p>{line}</p>
					))
				)}
			</section>

			{project.technologies && project.technologies.length > 0 && (
				<section class="project-section">
					<h2>Technologies Used</h2>
					<div class="tech-list">
						{project.technologies.map(tech => (
							<span class="tech-item">{tech}</span>
						))}
					</div>
				</section>
			)}
		</div>

			{project.pdf && (
				<section class="project-section">
					<h2>Download</h2>
					<a class="button-primary" href={project.pdf} download>Download PDF</a>
				</section>
			)}

			{project.link && (
				<section class="project-section">
					<h2>View Project</h2>
					<a class="button-primary" href={project.link} target="_blank">Visit Project →</a>
				</section>
			)}
		</div>
	</div>
</Layout>

<style>
	.project-detail-container {
		max-width: 900px;
		margin: 0 auto;
		padding: 40px 20px;
		font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
	}

	.back-link {
		display: inline-block;
		color: var(--color-dark);
		text-decoration: none;
		margin-bottom: 30px
		font-weight: 500;
		transition: color 0.2s;
		text-decoration: underline;
	}

	.back-link:hover {
		color: var(--color-secondary);
	}

	.project-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 30px;
		border-bottom: 2px solid #e5e7eb;
		padding-bottom: 20px;
	}

	.project-header h1 {
		margin: 0;
		font-size: 2.5em;
		color: #1f2937;
	}

	.category-badge {
		display: inline-block;
		background-color: var(--color-light);
		color: var(--text-color);
		padding: 8px 16px;
		border-radius: 20px;
		font-size: 0.9em;
		font-weight: 600;
	}

	.project-image-large {
		width: 100%;
		margin-bottom: 40px;
		border-radius: 8px;
		overflow: hidden;
	}

	.project-image-large img {
		width: 90%;
		height: auto;
		display: block;
	}

	.project-video {
		width: 100%;
		height: 0;
		padding-bottom: 56.25%;
		position: relative;
		margin-bottom: 40px;
		border-radius: 8px;
		overflow: hidden;
		background-color: #000;
	}

	.project-video iframe {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		border: 0;
	}

	.project-slideshow {
		width: 100%;
		margin-bottom: 40px;
	}

	.slideshow-container {
		position: relative;
		width: 100%;
		background-color: #f3f4f6;
		border-radius: 8px;
		overflow: hidden;
	}

	.slide {
		display: none;
		width: 100%;
	}

	.slide img {
	width: 100%;
	height: auto;
	display: block;
	object-fit: contain;
	}

	.slide.active {
		display: block;
	}

	.prev, .next {
		cursor: pointer;
		position: absolute;
		top: 50%;
		width: auto;
		margin-top: -22px;
		padding: 16px;
		color: white;
		font-weight: bold;
		font-size: 18px;
		transition: 0.3s ease;
		border-radius: 3px;
		background-color: rgba(0, 0, 0, 0.5);
		user-select: none;
		z-index: 10;
	}

	.next {
		right: 0;
	}

	.prev {
		left: 0;
	}

	.prev:hover, .next:hover {
		background-color: rgba(0, 0, 0, 0.8);
	}

	.dots {
		text-align: center;
		padding: 20px;
	}

	.dot {
		cursor: pointer;
		height: 12px;
		width: 12px;
		margin: 0 5px;
		background-color: #bbb;
		border-radius: 50%;
		display: inline-block;
		transition: background-color 0.3s ease;
	}

	.dot.active {
		background-color: var(--color-primary);
	}

	.project-content {
		font-size: 1.05em;
		line-height: 1.8;
	}

	.project-section {
		margin-bottom: 40px;
	}

	.project-section h2 {
		font-size: 1.5em;
		margin-bottom: 15px;
		border-bottom: 1px solid #d1d5db;
		padding-bottom: 10px;
	}

	.project-section p {
		margin: 0 0 15px 0;
	}

	.tech-list {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
	}

	.tech-item {
		display: inline-block;
		background-color: var(--color-light);
		color: var(--text-color);
		padding: 8px 16px;
		border-radius: 6px;
		font-weight: 500;
		border: 1px solid var(--color-border);
	}

	.button {
		display: inline-block;
		padding: 12px 24px;
		text-decoration: none;
		border-radius: 6px;
		transition: background-color 0.2s;
		border: none;
		cursor: pointer;
		font-size: 1em;
		font-weight: 600;
	}

	.button:hover {
		background-color: var(--color-primary-hover);
	}
	</style>
<script is:inline>
let slideIndex = 0;

function changeSlide(n) {
	showSlides(slideIndex += n);
}

function currentSlide(n) {
	showSlides(slideIndex = n);
}

function showSlides(n) {
	const slides = document.querySelectorAll('.slide');
	const dots = document.querySelectorAll('.dot');
	
	if (slides.length === 0) return;
	
	if (n >= slides.length) {
		slideIndex = 0;
	}
	if (n < 0) {
		slideIndex = slides.length - 1;
	}
	
	slides.forEach(slide => slide.classList.remove('active'));
	dots.forEach(dot => dot.classList.remove('active'));
	
	slides[slideIndex].classList.add('active');
	if (dots.length > slideIndex) {
		dots[slideIndex].classList.add('active');
	}
}

// Initialize slideshow
if (document.querySelectorAll('.slide').length > 0) {
	slideIndex = 0;
	showSlides(slideIndex);
}
</script>