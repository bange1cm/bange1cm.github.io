---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
---

<Layout>
	<Navigation />
	<div class="resume-container">
		<header class="resume-header">
			<h1>My Resume</h1>
			<div class="resume-links">
				<a href="/YerkeResume.pdf" class="button-primary" download>Download Resume</a>
			</div>
		</header>

		<section class="resume-section">
			<h2>Professional Experience</h2>
			<div class="experience-item">
				<div class="experience-header">
					<h3>UX Intern</h3>
					<span class="date">2025 - Present</span>
				</div>
				<p class="company">Auto-Owners Insurance</p>
				<p class="description">
					Faciliated usability studies from recruitment through analysis, synthesizing insights to inform design decisions. Conducted discovery research, including user interviews and data analysis, to identify user needs and pain points. Collaborated with cross functional teams and contributed to design reviews. 
				</p>
			</div>

					<div class="experience-item">
				<div class="experience-header">
					<h3>Java Teaching Assistant</h3>
					<span class="date">2025</span>
				</div>
				<p class="company">Central Michigan University</p>
				<p class="description">
					Supported student learning through regular office hours and one-on-one guidance on programming concepts and assignments. Evaluated and graded coursework, providing constructive feedback to reinforce understanding and improve student performance.				</p>
			</div>

			<div class="experience-item">
				<div class="experience-header">
					<h3>Software Development Intern</h3>
					<span class="date">2024</span>
				</div>
				<p class="company">Auto-Owners Insurance</p>
				<p class="description">
					Developed React features and integrated XML services for a Policy Administration System. Enhanced system performance and reliability by implementing 50+ new features and resolving 20+ software defects. Collaborated cross-functionally with UX designers, QA analysts, business analysts, and developers to ensure solutions aligned with project requirements and user needs.
				</p>
			</div>
            
			<div class="experience-item">
				<div class="experience-header">
					<h3>Systems Analyst Intern</h3>
					<span class="date">2023</span>
				</div>
				<p class="company">LMCU</p>
				<p class="description">
                    Supported IT operations by securly retiring and removing sensitive hard drives from 200+ legacy computers and completing documentation updates for 600+ company devices, including computers and printers. Assisted the PC support team with deployment and setup of phones, monitors, and docking stations, while maintaining organized asset tracking and equipment management.
				</p>
			</div>

			<div class="experience-item">
				<div class="experience-header">
					<h3>Help Desk Technician</h3>
					<span class="date">2023</span>
				</div>
				<p class="company">Central Michigan University, Office of Information Technology</p>
				<p class="description">
					Provided technical support for user accounts, campus systems, network connectivity, and Microsoft 365, resolving 250+ help desk tickets with a strong first-contact resolution rate. Delivered multi-channel support via email, phone, chat, remote access, and in-person assistance to ensure timely and effective issue resolution.				</p>
			</div>
		</section>

		<section class="resume-section">
			<h2>Education</h2>
			<div class="experience-item">
				<div class="experience-header">
					<h3>Bachelor of Science in Information Technology</h3>
					<span class="date">2026</span>
				</div>
				<p class="company">Central Michigan University</p>
				<p class="description">
                    Minors in Computer Science and Multimedia Design. CMU Honors Program. GPA: 4.0/4.0
				</p>
			</div>
		</section>

		<section class="resume-section">
			<h2>Skills</h2>
			<div class="skills-grid">
				<div class="skill-category">
					<h3>UX</h3>
					<ul>
						<li>Usability Studies</li>
						<li>User Interviews</li>
						<li>Accessibility (WCGA)</li>
                        <li>Wireframing & Prototyping</li>
                        <li>Design Thinking</li>
                        <li>Personas</li>
					</ul>
				</div>
				<div class="skill-category">
					<h3>Tools</h3>
					<ul>
						<li>Figma</li>
						<li>Axure</li>
						<li>Lucid</li>
                        <li>EnjoyHQ</li>
                        <li>UserZoom</li>
                        <li>Adobe Creative Suite</li>
                        <li>Git</li>
					</ul>
				</div>
                <div class="skill-category">
					<h3>Programming</h3>
					<ul>
						<li>React</li>
                        <li>HTML/CSS</li>
                        <li>Node.js</li>
                        <li>Python</li>
                        <li>Java</li>
                        <li>SQL</li>
                        <li>XML</li>
					</ul>
				</div>
			</div>
		</section>
	</div>
</Layout>

<style>
	.resume-container {
		max-width: 900px;
		margin: 0 auto;
		padding: 40px 20px;
		font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
	}

	.resume-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 40px;
		padding-bottom: 20px;
	}

	.resume-header h1 {
		margin: 0;
		font-size: 2.5em;
		color: var(--color-dark);
	}

	.resume-section {
		margin-bottom: 40px;
	}

	.resume-section h2 {
		font-size: 1.5em;
		margin-bottom: 20px;
		border-bottom: 1px solid #d1d5db;
		padding-bottom: 10px;
	}

	.experience-item {
		margin-bottom: 25px;
		padding: 15px;
		background-color: #f9fafb;
		border-left: 4px solid var(--color-secondary);
		border-radius: 4px;
	}

	.experience-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: 8px;
	}

	.experience-header h3 {
		margin: 0;		font-size: 1.1em;
	}

	.date {
		color: #6b7280;
		font-size: 0.9em;
		font-weight: 500;
	}

	.company {
		margin: 5px 0;
		color: #374151;
		font-weight: 600;
	}

	.description {
		margin: 10px 0 0 0;
		color: #4b5563;
		line-height: 1.6;
	}

	.skills-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 20px;
	}

	.skill-category {
		padding: 15px;
		background-color: #f9fafb;
		border-radius: 6px;
	}

	.skill-category h3 {
		margin-top: 0;
		color: #1f2937;
	}

	.skill-category ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.skill-category li {
		padding: 8px 0;
		color: #374151;
		border-bottom: 1px solid #e5e7eb;
	}

	.skill-category li:last-child {
		border-bottom: none;
	}
</style>
